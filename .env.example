# Kopieer dit bestand naar .env en vul de waarden in

# PostgreSQL connectie URL van Supabase
# Vind je in Supabase → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# Willekeurige geheime sleutel (verzin zelf iets)
SECRET_KEY=verander-dit-naar-iets-geheims
